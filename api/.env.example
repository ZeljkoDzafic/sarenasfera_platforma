# Sarena Sfera API Environment Variables
# Copy this file to .env and fill in the values

# Application
APP_NAME="Sarena Sfera API"
APP_VERSION="1.0.0"
ENVIRONMENT=development  # development, staging, production

# CORS (comma-separated list)
CORS_ORIGINS=["http://localhost:3000"]

# Supabase
SUPABASE_URL=http://localhost:54321
SUPABASE_ANON_KEY=copy-from-root-env-anon-key
SUPABASE_SERVICE_ROLE_KEY=copy-from-root-env-service-role-key

# Resend Email API
RESEND_API_KEY=re_your_api_key_here
RESEND_FROM_EMAIL=Šarena Sfera <noreply@sarenasfera.com>
INTERNAL_API_KEY=local-internal-api-key

# PDF Generation
PDF_BASE_URL=https://sarenasfera.com

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=60

# Logging
LOG_LEVEL=INFO
