# Sarena Sfera API Environment Variables
# Copy this file to .env and fill in the values

# Application
APP_NAME="Sarena Sfera API"
APP_VERSION="1.0.0"
ENVIRONMENT=development  # development, staging, production

# CORS (comma-separated list)
CORS_ORIGINS=http://localhost:3000,https://sarenasfera.com

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Resend Email API
RESEND_API_KEY=re_your_api_key_here
RESEND_FROM_EMAIL=Šarena Sfera <noreply@sarenasfera.com>

# PDF Generation
PDF_BASE_URL=https://sarenasfera.com

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=60

# Logging
LOG_LEVEL=INFO
