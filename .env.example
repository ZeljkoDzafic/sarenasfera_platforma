# ════════════════════════════════════════════════════════════
# Šarena Sfera Platforma — Production Environment
# ════════════════════════════════════════════════════════════
# Copy this to .env.production and fill in your values
# Never commit this file with real values!
# ════════════════════════════════════════════════════════════

# ───────────────────────────────────────────────────────────
# Application
# ───────────────────────────────────────────────────────────
NODE_ENV=production
ENVIRONMENT=production

# ───────────────────────────────────────────────────────────
# Domain & URLs
# ───────────────────────────────────────────────────────────
PUBLIC_URL=https://platforma.sarenasfera.com
SUPABASE_PUBLIC_URL=https://platforma.sarenasfera.com/supabase

# ───────────────────────────────────────────────────────────
# Supabase Configuration
# ───────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Supabase service role key (generate after first deploy)
SUPABASE_SERVICE_KEY=your-service-role-key

# Supabase anon key (generate after first deploy)
SUPABASE_ANON_KEY=your-anon-key

# ───────────────────────────────────────────────────────────
# Database
# ───────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 16
POSTGRES_PASSWORD=your-super-secure-postgres-password

POSTGRES_USER=postgres
POSTGRES_DB=sarenasfera
POSTGRES_HOST=db
POSTGRES_PORT=5432

# ───────────────────────────────────────────────────────────
# Email (Resend.com)
# ───────────────────────────────────────────────────────────
RESEND_API_KEY=re_your-api-key-here
EMAIL_FROM=noreply@sarenasfera.com
EMAIL_REPLY_TO=info@sarenasfera.com

# ───────────────────────────────────────────────────────────
# OAuth Providers (Optional)
# ───────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://platforma.sarenasfera.com/auth/callback

# ───────────────────────────────────────────────────────────
# Storage (S3-compatible)
# ───────────────────────────────────────────────────────────
# For DigitalOcean Spaces or AWS S3
STORAGE_ENDPOINT=
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
STORAGE_BUCKET=sarenasfera-storage
STORAGE_REGION=fra1

# ───────────────────────────────────────────────────────────
# Monitoring & Alerts
# ───────────────────────────────────────────────────────────
GRAFANA_PASSWORD=admin-secure-password-change-me
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# ───────────────────────────────────────────────────────────
# Backup Configuration
# ───────────────────────────────────────────────────────────
AWS_BUCKET_NAME=sarenasfera-backups
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# DigitalOcean Spaces (alternative)
DO_SPACES_BUCKET=sarenasfera-backups
DO_SPACES_ACCESS_KEY=
DO_SPACES_SECRET_KEY=
DO_SPACES_REGION=fra1

# ───────────────────────────────────────────────────────────
# Deployment Provider Specific
# ───────────────────────────────────────────────────────────

# DigitalOcean
DIGITALOCEAN_TOKEN=
DIGITALOCEAN_APP_ID=
DIGITALOCEAN_DROPLET_IP=
DIGITALOCEAN_SSH_KEY=

# AWS
AWS_ACCOUNT_ID=
AWS_ECR_REGISTRY=

# Azure
AZURE_REGISTRY_USERNAME=
AZURE_REGISTRY_PASSWORD=

# HostGator
HOSTGATOR_FTP_SERVER=ftp.hostgator.com
HOSTGATOR_FTP_USERNAME=
HOSTGATOR_FTP_PASSWORD=

# ───────────────────────────────────────────────────────────
# Security
# ───────────────────────────────────────────────────────────
# Rate limiting
API_RATE_LIMIT=100
GENERAL_RATE_LIMIT=500

# Session
SESSION_EXPIRY=86400
REFRESH_TOKEN_EXPIRY=604800

# ───────────────────────────────────────────────────────────
# Feature Flags
# ───────────────────────────────────────────────────────────
ENABLE_SIGNUPS=true
ENABLE_EMAIL_VERIFICATION=false
MAINTENANCE_MODE=false
