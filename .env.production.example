# ════════════════════════════════════════════════════════════
# Šarena Sfera Platforma — Production Environment
# ════════════════════════════════════════════════════════════
# ⚠️ SECURITY WARNING: Never commit this file with real values!
# Copy to .env.production and fill in your values.
# Review docs/SECURITY-BEST-PRACTICES.md before deploying.
# ════════════════════════════════════════════════════════════

# ───────────────────────────────────────────────────────────
# Application
# ───────────────────────────────────────────────────────────
NODE_ENV=production
NUXT_DEBUG_BUILD=false
NUXT_PUBLIC_SITE_URL=https://platforma.sarenasfera.com

# ───────────────────────────────────────────────────────────
# Supabase (CRITICAL: Use service role key ONLY on server)
# ───────────────────────────────────────────────────────────
# Public URL (safe to expose)
NUXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Anon key (safe for client-side)
NUXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Service role key (NEVER expose to client!)
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ───────────────────────────────────────────────────────────
# Database (Server-side ONLY)
# ───────────────────────────────────────────────────────────
# Generate secure password: openssl rand -hex 32
POSTGRES_PASSWORD=CHANGE_ME_USE_SECURE_PASSWORD

POSTGRES_USER=postgres
POSTGRES_DB=postgres
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Connection pool settings
POSTGRES_POOL_SIZE=10
POSTGRES_IDLE_TIMEOUT=30000

# ───────────────────────────────────────────────────────────
# Authentication & Security
# ───────────────────────────────────────────────────────────
# Generate: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_USE_SECURE_SECRET
INTERNAL_API_KEY=CHANGE_ME_USE_INTERNAL_API_KEY
ADMIN_PASSWORD=CHANGE_ME_USE_SECURE_ADMIN_PASSWORD

# Session settings
SESSION_EXPIRY=86400
REFRESH_TOKEN_EXPIRY=604800

# Password requirements
PASSWORD_MIN_LENGTH=8
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_NUMBER=true
PASSWORD_REQUIRE_SPECIAL=false

# Rate limiting
LOGIN_RATE_LIMIT=5
LOGIN_RATE_LIMIT_WINDOW=15

# CORS
CORS_ORIGIN=https://platforma.sarenasfera.com
CORS_METHODS=GET,POST,PUT,DELETE

# ───────────────────────────────────────────────────────────
# Email Configuration (Resend.com)
# ───────────────────────────────────────────────────────────
RESEND_API_KEY=re_your-api-key-here
EMAIL_FROM=noreply@sarenasfera.com
EMAIL_REPLY_TO=info@sarenasfera.com
EMAIL_TEST_MODE=false

# ───────────────────────────────────────────────────────────
# File Storage (Supabase Storage or S3)
# ───────────────────────────────────────────────────────────
STORAGE_PROVIDER=supabase
# or: STORAGE_PROVIDER=s3

# Supabase Storage
STORAGE_BUCKET=sarenasfera-storage

# S3 (if using)
S3_ENDPOINT=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=
S3_REGION=eu-central-1

# Upload limits
MAX_FILE_SIZE=5242880
MAX_IMAGE_SIZE=10485760
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/webp,application/pdf

# ───────────────────────────────────────────────────────────
# Monitoring & Logging
# ───────────────────────────────────────────────────────────
LOG_LEVEL=warn
LOG_FORMAT=json

# Sentry (error tracking)
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1

# Discord alerts (optional)
DISCORD_WEBHOOK_URL=
DISCORD_ALERT_LEVEL=error

# ───────────────────────────────────────────────────────────
# Backup Configuration
# ───────────────────────────────────────────────────────────
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30

# S3 for backups (recommended)
BACKUP_S3_BUCKET=sarenasfera-backups
BACKUP_S3_ACCESS_KEY=
BACKUP_S3_SECRET_KEY=
BACKUP_S3_REGION=eu-central-1

# ───────────────────────────────────────────────────────────
# Performance
# ───────────────────────────────────────────────────────────
# Caching
CACHE_TTL=3600
CACHE_CONTROL_PUBLIC=max-age=31536000, immutable

# Compression
COMPRESSION_ENABLED=true
COMPRESSION_LEVEL=6

# CDN
CDN_URL=https://cdn.sarenasfera.com
CDN_ENABLED=false

# ───────────────────────────────────────────────────────────
# Feature Flags
# ───────────────────────────────────────────────────────────
ENABLE_SIGNUPS=true
ENABLE_EMAIL_VERIFICATION=false
ENABLE_WAITLIST=false
MAINTENANCE_MODE=false

# ───────────────────────────────────────────────────────────
# Third-party Services
# ───────────────────────────────────────────────────────────
# Analytics (optional)
ANALYTICS_ID=
ANALYTICS_ENABLED=false

# reCAPTCHA (for forms)
RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=
RECAPTCHA_ENABLED=false

# ───────────────────────────────────────────────────────────
# Deployment Provider Specific
# ───────────────────────────────────────────────────────────

# DigitalOcean
DIGITALOCEAN_TOKEN=
DIGITALOCEAN_APP_ID=
DIGITALOCEAN_DROPLET_IP=
DIGITALOCEAN_SSH_KEY=

# AWS
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=eu-central-1
AWS_ACCOUNT_ID=

# Azure
AZURE_CREDENTIALS=
AZURE_REGISTRY_USERNAME=
AZURE_REGISTRY_PASSWORD=

# HostGator
HOSTGATOR_FTP_SERVER=
HOSTGATOR_FTP_USERNAME=
HOSTGATOR_FTP_PASSWORD=

# ───────────────────────────────────────────────────────────
# SSL/TLS (for Docker deployments)
# ───────────────────────────────────────────────────────────
SSL_ENABLED=true
SSL_CERT_PATH=/etc/letsencrypt/live/platforma.sarenasfera.com/fullchain.pem
SSL_KEY_PATH=/etc/letsencrypt/live/platforma.sarenasfera.com/privkey.pem

# Let's Encrypt
LETSENCRYPT_EMAIL=admin@sarenasfera.com
LETSENCRYPT_STAGING=false

# ───────────────────────────────────────────────────────────
# Security Headers
# ───────────────────────────────────────────────────────────
HSTS_ENABLED=true
HSTS_MAX_AGE=31536000
HSTS_INCLUDE_SUBDOMAINS=true
HSTS_PRELOAD=true

# ───────────────────────────────────────────────────────────
# Runtime Config (Nuxt)
# ───────────────────────────────────────────────────────────
# Keep this file to plain KEY=VALUE entries only.
# Nuxt runtime config is derived from the individual variables above.
